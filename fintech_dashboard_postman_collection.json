		{
			"name": "Sync Operations",
			"item": [
				{
					"name": "Batch Sync (If DB Empty)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"transactions\": [\n        {\n            \"date\": \"2nd April\",\n            \"description\": \"Entity 401\",\n            \"amount\": 1000,\n            \"gst\": 180,\n            \"total\": 1180,\n            \"type\": \"income\"\n        }\n    ],\n    \"liabilities\": [\n        {\n            \"date\": \"2nd April\",\n            \"account\": \"HDFC\",\n            \"description\": \"Rent\",\n            \"amount\": 1000,\n            \"type\": \"credit\"\n        }\n    ],\n    \"accounts\": [\n        {\n            \"name\": \"Entity 401\"\n        }\n    ]\n}",
